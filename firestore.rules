rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // The app stores all learner state in a single document per user:
    //   users/{uid} = {
    //     progress: { [lessonId]: LessonProgress },
    //     quizzes:  { [lessonId]: QuizResult },
    //     stats:    UserStats,
    //     mistakes: { [lessonId]: Mistake[] },
    //     antArmy:  { [topicId]: ArmyAnt[] },
    //     battle:   { [levelId]: BattleLevelResult },
    //   }
    // (see src/data/persistence.ts and src/types.ts)

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Validates the UserStats sub-object.
    function isValidStats(s) {
      return s is map
        && s.keys().hasOnly(['currentStreak', 'lastActiveDate', 'lessonsCompletedCount'])
        && s.currentStreak is int && s.currentStreak >= 0 && s.currentStreak <= 100000
        && (s.lastActiveDate == null || (s.lastActiveDate is string && s.lastActiveDate.size() <= 10))
        && s.lessonsCompletedCount is int
        && s.lessonsCompletedCount >= 0
        && s.lessonsCompletedCount <= 100000;
    }

    // Validates the quizzes map of lessonId -> QuizResult.
    function isValidQuizzes(q) {
      // Cap collection size to prevent storage abuse / DoS.
      return q is map && q.size() <= 200;
    }

    // Validates the mistakes map of lessonId -> Mistake[] (the Ant Colony).
    function isValidMistakes(m) {
      // Cap collection size to prevent storage abuse / DoS.
      return m is map && m.size() <= 200;
    }

    // Validates the antArmy map of topicId -> ArmyAnt[] (the Ant Army base).
    function isValidAntArmy(a) {
      // One anthill per topic (6 today); cap generously to prevent abuse.
      return a is map && a.size() <= 50;
    }

    // Validates the battle map of levelId -> BattleLevelResult (Battle mode).
    function isValidBattle(b) {
      // One entry per campaign level; cap generously to prevent abuse.
      return b is map && b.size() <= 200;
    }

    // Validates the resulting user document (works for create and merge-update,
    // since request.resource.data is the full post-write document).
    function isValidUserDoc(data) {
      return data.keys().hasOnly(['progress', 'quizzes', 'stats', 'mistakes', 'antArmy', 'battle'])
        // Cap collection size to prevent storage abuse / DoS.
        && (!('progress' in data) || (data.progress is map && data.progress.size() <= 200))
        && (!('quizzes' in data) || isValidQuizzes(data.quizzes))
        && (!('stats' in data) || isValidStats(data.stats))
        && (!('mistakes' in data) || isValidMistakes(data.mistakes))
        && (!('antArmy' in data) || isValidAntArmy(data.antArmy))
        && (!('battle' in data) || isValidBattle(data.battle));
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow delete: if isOwner(uid);
      allow create, update: if isOwner(uid) && isValidUserDoc(request.resource.data);
    }

    // Default deny: anything not explicitly matched above is inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
