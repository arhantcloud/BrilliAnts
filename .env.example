# Copy to .env and fill in your Firebase project's web app config.
# When these are absent, the app runs in local (offline) mode using
# localStorage for auth + progress, so you can develop without Firebase.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# LOCAL DEV ONLY. Enables the Ant Colony "Ask Andi" AI tutor by calling OpenAI
# directly from the browser. This key is only read behind import.meta.env.DEV,
# so it is stripped from production builds. NEVER set this in a deployed/prod
# environment (Vite inlines VITE_* vars into the shipped bundle).
VITE_OPENAI_API_KEY=
